# ── Supabase ──────────────────────────────────────────────────
# Get these from your Supabase project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY   # Server-side only, never expose to client

# ── API-Football ──────────────────────────────────────────────
# Free at rapidapi.com → search "API-Football" → subscribe to free tier
API_FOOTBALL_KEY=YOUR_RAPIDAPI_KEY
API_FOOTBALL_HOST=v3.football.api-sports.io

# ── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000   # Change to your Vercel URL after deployment
ADMIN_SECRET=change_this_to_a_random_secret  # Used to protect admin API routes
